    }

    function heroDots() {
      return heroData.map((point) => {
        const cx = 26 + ((point.x - 0.6) / (6.4 - 0.6)) * 508;
        const cy = 184 - ((point.observed - 2.3) / (6.62 - 2.3)) * 150;
        return `<circle cx="${cx}" cy="${cy}" r="4.5" fill="#e5e7eb" stroke="#ffffff" stroke-width="1.2"></circle>`;
      }).join("");
    }

    function renderMethods() {
