            ].map(([id, label]) => `<button class="pill${activeMethodsView === id ? " active" : ""}" data-method-view="${id}">${label}</button>`).join("")}
          </div>
          ${activeMethodsView === "comparison" ? `
          <div class="card">
            <h2 class="subtitle" style="font-size:30px;margin-top:0;">Method Comparison</h2>
            <div class="table-wrap" style="margin-top:24px;">
              <table>
                <thead>
                  <tr>
                    <th>Method</th>
