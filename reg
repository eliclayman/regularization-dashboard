    function drawHeroChart(canvas, modeIndex) {
      const ctx = canvas.getContext("2d");
      const { width, height } = canvas;
      ctx.clearRect(0, 0, width, height);
      ctx.fillStyle = "#071120";
      ctx.fillRect(0, 0, width, height);

      const padding = { top: 24, right: 24, bottom: 58, left: 52 };
      const innerW = width - padding.left - padding.right;
      const innerH = height - padding.top - padding.bottom;
      const minX = 0.4, maxX = 6.6, minY = 1.6, maxY = 7.0;
      const px = (x) => padding.left + ((x - minX) / (maxX - minX)) * innerW;
      const py = (y) => padding.top + (1 - (y - minY) / (maxY - minY)) * innerH;

      ctx.strokeStyle = "rgba(148,163,184,0.18)";
      [2, 3, 4, 5, 6].forEach((y) => {
        ctx.beginPath();
        ctx.moveTo(padding.left, py(y));
        ctx.lineTo(width - padding.right, py(y));
        ctx.stroke();
      });
      [1, 2, 3, 4, 5, 6].forEach((x) => {
        ctx.beginPath();
        ctx.moveTo(px(x), padding.top);
        ctx.lineTo(px(x), height - padding.bottom);
        ctx.stroke();
      });

      ctx.strokeStyle = "rgba(148,163,184,0.45)";
      ctx.beginPath();
      ctx.moveTo(padding.left, padding.top);
      ctx.lineTo(padding.left, height - padding.bottom);
      ctx.lineTo(width - padding.right, height - padding.bottom);
      ctx.stroke();

      ctx.fillStyle = "#9aacbf";
      ctx.font = "12px Inter";
      ctx.fillText("Predicted outcome", 6, 16);
      ctx.fillText("Feature value", width - 110, height - 12);

      const lines = [
        { key: "underfit", color: "#fca5a5" },
        { key: "goodFit", color: "#86efac" },
        { key: "overfit", color: "#fca5a5" }
      ];

      lines.forEach((line, index) => {
        ctx.beginPath();
        heroData.forEach((point, pointIndex) => {
          const x = px(point.x);
          const y = py(point[line.key]);
          if (pointIndex === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        });
        ctx.strokeStyle = line.color;
        ctx.globalAlpha = modeIndex === index ? 1 : 0.26;
        ctx.lineWidth = line.key === "goodFit" ? 4 : 3;
        ctx.stroke();
        ctx.globalAlpha = 1;
      });

      heroData.forEach((point) => {
        ctx.beginPath();
        ctx.arc(px(point.x), py(point.observed), 4.5, 0, Math.PI * 2);
        ctx.fillStyle = "#e5e7eb";
        ctx.fill();
        ctx.strokeStyle = "#ffffff";
        ctx.lineWidth = 1.2;
        ctx.stroke();
      });
    }

    renderTabs();
    renderView();
  </script>
