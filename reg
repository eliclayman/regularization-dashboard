<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Regularization</title>
  <style>
    :root {
      --panel: rgba(15, 23, 42, 0.76);
      --panel-soft: rgba(255, 255, 255, 0.04);
      --border: rgba(148, 163, 184, 0.12);
      --text: #e7eef9;
      --muted: #9aacbf;
      --accent: #60c7ff;
      --red: #fca5a5;
      --green: #86efac;
      --shadow: 0 24px 60px rgba(2, 6, 23, 0.34);
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: Inter, ui-sans-serif, system-ui, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(96, 199, 255, 0.14), transparent 24%),
        linear-gradient(180deg, #09111f 0%, #020817 100%);
    }
    button { font: inherit; }
    .app { min-height: 100vh; padding: 24px 16px 40px; }
    .shell { max-width: 1120px; margin: 0 auto; }
    .nav {
      position: sticky;
      top: 12px;
      z-index: 20;
      border: 1px solid var(--border);
      background: rgba(9, 17, 31, 0.84);
      backdrop-filter: blur(18px);
      border-radius: 24px;
      padding: 16px 18px;
      box-shadow: var(--shadow);
    }
    .nav-row {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 18px;
    }
    .brand {
      font-size: 28px;
      font-weight: 700;
      letter-spacing: -0.03em;
      align-self: flex-start;
    }
    .tabs-wrapper {
      width: 100%;
      display: flex;
      justify-content: center;
    }
    .tabs {
      display: flex;
      gap: 12px;
      overflow-x: auto;
      padding-bottom: 2px;
      max-width: 100%;
    }
    .tab {
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.04);
      color: var(--muted);
      border-radius: 999px;
      padding: 10px 14px;
      white-space: nowrap;
      cursor: pointer;
      transition: opacity 180ms ease, background-color 180ms ease, color 180ms ease, border-color 180ms ease;
    }
    .tab.active {
      background: var(--accent);
      color: #06111e;
      border-color: transparent;
      font-weight: 700;
    }
    .theme-btn {
      margin-top: 18px;
      margin-left: auto;
      width: fit-content;
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.04);
      color: var(--text);
      border-radius: 999px;
      padding: 10px 14px;
      cursor: pointer;
    }
    .view {
      max-width: 900px;
      min-height: calc(100vh - 170px);
      margin: 28px auto 0;
      border: 1px solid var(--border);
      background: var(--panel);
      border-radius: 34px;
      padding: 42px 32px;
      box-shadow: var(--shadow);
      backdrop-filter: blur(16px);
      animation: fadeUp 0.22s ease;
    }
    .title {
      margin: 0;
      color: var(--accent);
      font-size: clamp(38px, 6vw, 54px);
      line-height: 1.02;
      letter-spacing: -0.04em;
    }
    .subtitle {
      margin: 18px 0 0;
      font-size: 28px;
      line-height: 1.15;
      color: white;
    }
    .lead {
      max-width: 760px;
      margin: 18px 0 0;
      color: var(--muted);
      line-height: 1.85;
      font-size: 17px;
    }
    .stack { display: grid; gap: 34px; margin-top: 38px; }
    .grid-2 { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 20px; }
    .soft-block, .card, .example-row {
      background: var(--panel-soft);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 24px;
      padding: 24px;
      min-height: 100%;
      box-shadow: 0 8px 24px rgba(2, 6, 23, 0.16);
    }
    .soft-block h3, .card h3, .example-row h3 { margin: 0; font-size: 20px; }
    .soft-block p, .card p, .example-row p, .soft-block li {
      margin: 12px 0 0;
      color: var(--muted);
      line-height: 1.8;
      font-size: 15px;
      white-space: pre-line;
    }
    .soft-block ul { margin: 12px 0 0; padding-left: 0; list-style: none; }
    .italic-note {
      margin-top: 16px;
      color: #94a3b8;
      font-size: 14px;
      font-style: italic;
      line-height: 1.8;
    }
    .compare {
      border: 1px solid var(--border);
      background: rgba(5, 10, 22, 0.34);
      border-radius: 24px;
      padding: 24px;
      min-height: 100%;
      box-shadow: 0 8px 24px rgba(2, 6, 23, 0.16);
    }
    .compare h3 { margin: 0; font-size: 22px; }
    .compare p { margin: 12px 0 0; color: var(--muted); line-height: 1.8; }
    .chart-shell {
      border: 1px solid var(--border);
      background: rgba(5, 10, 22, 0.34);
      border-radius: 28px;
      padding: 22px;
    }
    .chart-shell h3 { margin: 0; font-size: 20px; }
    .chart-shell p { margin: 8px 0 0; color: var(--muted); font-size: 14px; }
    .pills {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 16px;
    }
    .pill {
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.04);
      color: var(--muted);
      border-radius: 999px;
      padding: 10px 14px;
      cursor: pointer;
      transition: opacity 180ms ease, background-color 180ms ease, color 180ms ease, border-color 180ms ease;
    }
    .pill.active {
      background: var(--accent);
      color: #06111e;
      border-color: transparent;
      font-weight: 700;
    }
    .info-box {
      margin-top: 18px;
      border: 1px solid var(--border);
      background: rgba(5, 10, 22, 0.34);
      border-radius: 24px;
      padding: 22px;
    }
    .info-box h3 { margin: 0; font-size: 20px; }
    .info-box p { margin: 12px 0 0; line-height: 1.8; }
    .instruction { margin-top: 20px; color: var(--muted); font-size: 14px; }
    .table-wrap {
      overflow: auto;
      border-radius: 24px;
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.02);
    }
    table {
      width: 100%;
      min-width: 720px;
      border-collapse: collapse;
      text-align: left;
    }
    th, td {
      padding: 16px 18px;
      border-bottom: 1px solid rgba(148, 163, 184, 0.1);
    }
    th { color: #dce8f7; font-size: 14px; }
    td { color: var(--muted); font-size: 14px; line-height: 1.7; }
    td:first-child { color: white; font-weight: 700; }
    tbody tr:hover { background: rgba(255,255,255,0.04); }
    canvas { width: 100%; display: block; }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @media (max-width: 860px) {
      .view { padding: 28px 20px; }
      .grid-2 { grid-template-columns: 1fr; }
      .nav-row { align-items: flex-start; }
      .brand { font-size: 24px; }
      .subtitle { font-size: 24px; }
    }
  </style>
</head>
<body>
  <div class="app">
    <div class="shell">
      <header class="nav">
        <div class="nav-row">
          <div class="brand">Regularization</div>
          <div class="tabs-wrapper">
            <nav class="tabs" id="tabs"></nav>
          </div>
        </div>
      </header>
      <main id="view" class="view"></main>
    </div>
  </div>

  <script>
    const tabs = [
      { id: "simply-explained", label: "Simply Explained" },
      { id: "intuition", label: "Intuition" },
      { id: "regression", label: "Regression" },
      { id: "methods", label: "Methods" },
      { id: "modern", label: "State of the Art" },
      { id: "quiz", label: "Quiz" },
      { id: "ai-usage", label: "AI Usage" }
    ];

    const intuitionModes = [
      {
        label: "Underfit",
        title: "Underfit",
        text: "Too simple. The model misses the real pattern in the data."
      },
      {
        label: "Good Fit",
        title: "Good Fit",
        text: "Captures the real pattern without chasing noise."
      },
      {
        label: "Overfit",
        title: "Overfit",
        text: "Too complex. The model follows noise instead of the true signal."
      }
    ];

    const heroData = [
      { x: 0.6, observed: 2.3, underfit: 3.08, goodFit: 2.25, overfit: 2.28 },
      { x: 1.2, observed: 2.95, underfit: 3.34, goodFit: 2.88, overfit: 2.94 },
      { x: 1.9, observed: 4.55, underfit: 3.66, goodFit: 4.18, overfit: 4.52 },
      { x: 2.5, observed: 4.12, underfit: 3.93, goodFit: 4.48, overfit: 4.11 },
      { x: 3.2, observed: 5.72, underfit: 4.25, goodFit: 5.53, overfit: 5.69 },
      { x: 3.9, observed: 5.08, underfit: 4.57, goodFit: 5.32, overfit: 5.1 },
      { x: 4.5, observed: 6.62, underfit: 4.84, goodFit: 6.28, overfit: 6.58 },
      { x: 5.1, observed: 5.6, underfit: 5.12, goodFit: 5.96, overfit: 5.63 },
      { x: 5.8, observed: 6.18, underfit: 5.43, goodFit: 6.14, overfit: 6.16 },
      { x: 6.4, observed: 5.32, underfit: 5.71, goodFit: 5.44, overfit: 5.34 }
    ];

    const tabsEl = document.getElementById("tabs");
    const viewEl = document.getElementById("view");

    let activeTab = "simply-explained";
    let activeIntuitionMode = 1;
    let activeMethod = "ridge";
    let activeMethodsView = "ridge";
    let activeAIUsage = "concept-simplification";
    let activeQuizIndex = 0;
    let quizSelections = {};
    let quizChecked = {};
    let quizComplete = false;

    const methodsData = {
      ridge: {
        title: "Ridge",
        what: "Shrinks all coefficients by applying a penalty, but keeps every feature in the model.",
        best: "Features are highly correlated and you want to keep all of them while reducing instability.",
        why: "When features overlap in information, Ridge spreads the influence across them instead of letting any single coefficient become too large.",
        prosCons: "Pro: Stable with correlated features\nRidge reduces variance and prevents coefficients from becoming large and unstable when features are similar.\n\nCon: No feature selection\nIt keeps all features in the model, even those that may not be important, which can make interpretation harder.",
        example: "Predicting house prices where many features (size, number of rooms, location) are related and all contribute some information."
      },
      lasso: {
        title: "Lasso",
        what: "Shrinks coefficients and pushes some exactly to zero, effectively removing less important features.",
        best: "You want a simpler model and need to identify the most important features.",
        why: "By removing unnecessary features, Lasso reduces noise and makes the model easier to interpret.",
        prosCons: "Pro: Performs automatic feature selection\nLasso simplifies the model by keeping only the most important features.\n\nCon: Unstable with correlated features\nWhen features are highly correlated, Lasso may randomly select one and ignore others, even if they are equally important.",
        example: "Predicting disease risk using many medical variables. In reality, only a few variables strongly affect the outcome. Lasso removes the less important ones by setting their coefficients to zero, leaving a simpler and more interpretable model focused on the key risk factors."
      },
      "elastic-net": {
        title: "Elastic Net",
        what: "Combines Ridge and Lasso by shrinking coefficients while also allowing some to be removed.",
        best: "Features are highly correlated and you still want feature selection without instability.",
        why: "Lasso can randomly drop one feature from a group of correlated features. Elastic Net keeps groups of related features while still simplifying the model.",
        prosCons: "Pro: Handles correlated features well\nElastic Net tends to keep groups of related features instead of selecting one arbitrarily, making the model more stable than Lasso.\n\nCon: More parameters to tune\nIt introduces an extra parameter that controls the balance between Ridge and Lasso, making the model slightly more complex to tune.",
        example: "Analyzing text data where many words have similar meanings and tend to appear together. Lasso might randomly drop some of these words, even if they are useful. Elastic Net keeps groups of related words while still simplifying the model, leading to better and more stable predictions."
      },
      "svd-pca": {
        title: "SVD (Singular Value Decomposition)",
        what: "Breaks the data into components based on their importance. Smaller components often represent noise.",
        best: "Data has many correlated features and you want to simplify it.",
        connection: "Regularization methods like Ridge and Lasso control complexity by penalizing coefficients.\n\nSVD approaches the problem differently. It decomposes the data into components and allows us to ignore the smaller, less important ones.\n\nBy removing these weaker components, the model becomes simpler and less sensitive to noise, which helps prevent overfitting.",
        prosCons: "Pro: Dimensionality Reduction\nSVD can represent large datasets using a smaller number of components (Truncated SVD). This reduces memory usage and speeds up training for models like Ridge or Lasso.\n\nCon: Computational Cost\nComputing full SVD is expensive for very large datasets (on the order of O(min(mn^2, m^2n))). In practice, approximate methods like Randomized SVD are often used instead.",
        pros: ["Reduces noise", "Improves stability"],
        cons: ["Harder to interpret", "Loses some information"],
        example: "Working with a large dataset that contains many overlapping or redundant features. SVD breaks the data into core components and removes weaker ones that mostly capture noise. This reduces complexity and helps the model focus on the most important patterns."
      }
    };

    const aiUsageData = {
      "concept-simplification": {
        title: "Concept simplification",
        description: "AI was used to translate technical concepts into simple, intuitive explanations and analogies.",
        prompt: "Explain regularization in the simplest way possible. Avoid math and focus on intuition. Use a real-life analogy, like studying for a test, to explain overfitting vs generalization."
      },
      "ui-ux-design": {
        title: "UI / UX design",
        description: "AI helped improve layout decisions, remove unnecessary components, and simplify interactions.",
        prompt: "I have a tab with underfit, good fit, and overfit. The current slider feels unnecessary. Suggest a cleaner UI where users can switch between the three states and clearly see the difference visually."
      },
      "content-refinement": {
        title: "Content refinement",
        description: "AI was used to rewrite and tighten explanations to make them clearer and easier to understand.",
        prompt: 'Rewrite this explanation so it is simpler, clearer, and more intuitive:\n"Regularization adds a penalty to model complexity to improve generalization."\nKeep it short and understandable for someone seeing this for the first time.'
      },
      "real-world-examples": {
        title: "Real-world examples",
        description: "AI helped generate practical examples showing how regularization applies in real scenarios.",
        prompt: "Give simple real-world examples of regularization in finance, Spotify music recommendations, and medicine. Focus on what goes wrong with overfitting and how regularization fixes it."
      },
      "code-debugging": {
        title: "Code and debugging",
        description: "AI assisted with layout fixes and front-end improvements during development.",
        prompt: "Fix this layout issue: the navigation tabs are not centered. Use flexbox to center them horizontally without affecting the title alignment. Avoid using margin hacks."
      }
    };

    const quizQuestions = [
      {
        id: 1,
        question: "What is “underfitting”?",
        options: [
          "A. The model is too simple and misses the real pattern",
          "B. The model fits noise in the training data",
          "C. The model uses too many features",
          "D. The model memorizes every training point"
        ],
        correctAnswer: "A",
        feedback: "Underfitting happens when the model is too simple to capture the real pattern in the data."
      },
      {
        id: 2,
        question: "You train a model and get very low training error but high test error. What is the best explanation?",
        options: [
          "A. The value of λ is probably too large.",
          "B. The model is underfitting because it is too simple.",
          "C. The model is overfitting because it learned noise in the training data.",
          "D. The model has too much bias and too little variance."
        ],
        correctAnswer: "C",
        feedback: "Low training error with high test error usually means overfitting. The model fits the training data too closely, including random noise, so it performs poorly on new data."
      },
      {
        id: 3,
        question: "You have many highly correlated features and want feature selection, but you do not want Lasso to randomly drop useful correlated variables. Which method is usually best?",
        options: [
          "A. Ridge",
          "B. Lasso",
          "C. Ordinary least squares",
          "D. Elastic Net"
        ],
        correctAnswer: "D",
        feedback: "Elastic Net combines Ridge and Lasso. It can perform feature selection while handling correlated features more stably than Lasso alone."
      },
      {
        id: 4,
        question: "What is the main difference between Ridge and Lasso as described in the slides?",
        options: [
          "A. Ridge shrinks coefficients but keeps all features, while Lasso can set some coefficients to zero",
          "B. Ridge removes features, while Lasso keeps all features",
          "C. Ridge increases model complexity, while Lasso decreases it",
          "D. Ridge only works with uncorrelated features, while Lasso only works with correlated features"
        ],
        correctAnswer: "A",
        feedback: "Ridge shrinks coefficients but keeps every feature in the model, while Lasso can push some coefficients exactly to zero and remove less important features."
      }
    ];

    function renderTabs() {
      tabsEl.innerHTML = "";
      tabs.forEach((tab) => {
        const btn = document.createElement("button");
        btn.className = "tab" + (tab.id === activeTab ? " active" : "");
        btn.textContent = tab.label;
        btn.addEventListener("click", () => {
          activeTab = tab.id;
          renderTabs();
          renderView();
        });
        tabsEl.appendChild(btn);
      });
    }

    function renderSimplyExplained() {
      viewEl.innerHTML = `
        <h1 class="title">Simply Explained</h1>
        <h2 class="subtitle">Regularization keeps models under control</h2>
        <p class="lead">A model can fit training data too closely and start learning noise instead of real patterns. Regularization adds a small cost for complexity, controlled by a parameter called λ, so the model stays useful on new data.</p>
        <div class="stack">
          <div class="grid-2" style="grid-template-columns:minmax(0, 1.1fr) minmax(0, 0.9fr); align-items:start;">
            <div class="soft-block">
              <div>
                <h3>What regularization means</h3>
                <p>Regularization forces the model to stay simple so it works on new data, not just the training data. Like a student studying for a test, it’s better to learn concepts that apply to all problems rather than memorize specific questions and hope they appear again.</p>
              </div>
              <div style="margin-top:24px; padding-top:24px; border-top:1px solid rgba(255,255,255,0.06);">
                <h3>Why regularization helps</h3>
                <p>Complex models often learn noise in the training data, which leads to mistakes on new data. Simpler models focus on real patterns, so they generalize better and perform more reliably.</p>
              </div>
              <div style="margin-top:24px; padding-top:24px; border-top:1px solid rgba(255,255,255,0.06);">
                <h3>What problems does regularization solve?</h3>
                <p>Regularization helps control:
• Large coefficients that make the model unstable
• Excessive complexity that leads to overfitting</p>
              </div>
            </div>
            <div class="soft-block">
              <h3>What λ does</h3>
              <div style="display:grid; gap:10px; margin-top:18px;">
                <p style="margin:0; color:var(--muted); line-height:1.8;"><span style="color:white; font-weight:600;">Small λ:</span> Fits everything, including noise</p>
                <p style="margin:0; color:#c6eaff; line-height:1.8;"><span style="color:#dff4ff; font-weight:600;">Balanced λ:</span> Captures real patterns and generalizes well</p>
                <p style="margin:0; color:var(--muted); line-height:1.8;"><span style="color:white; font-weight:600;">Large λ:</span> Too simple and misses patterns</p>
              </div>
              <div style="margin-top:24px; padding-top:22px; border-top:1px solid rgba(255,255,255,0.06);">
                <p style="margin:0; color:#e7eef9; font-size:14px; font-weight:600; line-height:1.6;">Regularized regression objective</p>
                <p style="margin:12px 0 0; color:#dce8f7; font-size:17px; line-height:1.7; letter-spacing:0.01em;">‖y − Xw‖² + λ Σ(wᵢ²)</p>
                <div style="margin-top:18px; display:grid; gap:14px;">
                  <div>
                    <p style="margin:0; color:#e7eef9; font-size:14px; font-weight:600; line-height:1.6;">‖y − Xw‖²</p>
                    <p class="italic-note" style="margin-top:6px;">This is the fit term. It measures how closely the model predictions match the observed data.</p>
                  </div>
                  <div>
                    <p style="margin:0; color:#e7eef9; font-size:14px; font-weight:600; line-height:1.6;">λ Σ(wᵢ²)</p>
                    <p class="italic-note" style="margin-top:6px;">This is the penalty term. It discourages large coefficients, which helps keep the model simpler and more stable.</p>
                  </div>
                  <div>
                    <p style="margin:0; color:#e7eef9; font-size:14px; font-weight:600; line-height:1.6;">λ</p>
                    <p class="italic-note" style="margin-top:6px;">Lambda controls the strength of the penalty.</p>
                    <p class="italic-note" style="margin-top:6px;">When λ = 0, the model reduces to standard linear regression.</p>
                    <p class="italic-note" style="margin-top:6px;">A larger λ forces the coefficients to be smaller, leading to a simpler model.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      `;
    }

    function renderIntuition() {
      viewEl.innerHTML = `
        <h1 class="title">Graphic Intuition</h1>
        <p class="lead">The same data can lead to very different models. The goal is to capture the real pattern without learning the noise.</p>
        <div class="stack">
          <div class="chart-shell">
            <div style="margin-top:4px;"><canvas id="heroCanvas" width="760" height="360"></canvas></div>
          </div>
          <p class="instruction">Select a model to see how it behaves.</p>
          <div class="pills">
            ${intuitionModes.map((mode, index) => `<button class="pill${index === activeIntuitionMode ? " active" : ""}" data-mode="${index}">${mode.label}</button>`).join("")}
          </div>
          <div class="info-box">
            <h3 style="color:${activeIntuitionMode === 1 ? "var(--green)" : "var(--red)"}">${intuitionModes[activeIntuitionMode].title}</h3>
            <p style="color:${activeIntuitionMode === 1 ? "var(--green)" : "var(--red)"}">${intuitionModes[activeIntuitionMode].text}</p>
          </div>
        </div>
      `;

      document.querySelectorAll("[data-mode]").forEach((btn) => {
        btn.addEventListener("click", () => {
          activeIntuitionMode = Number(btn.dataset.mode);
          renderView();
        });
      });
      drawHeroChart(document.getElementById("heroCanvas"), activeIntuitionMode);
    }

    function renderRegression() {
      viewEl.innerHTML = `
        <h1 class="title">Regression</h1>
        <h2 class="subtitle">Regularization changes how regression behaves</h2>
        <p class="lead">Ordinary regression focuses only on fitting the training data. This can lead to unstable models, especially when features are noisy or correlated. Regularization adds a small constraint that keeps the model more stable and reliable on new data.</p>
        <div class="stack">
          <div class="card">
            <div class="grid-2">
              <div class="compare">
                <h3>No regularization</h3>
                <div style="margin-top:16px;">
                  <svg viewBox="0 0 560 220" style="width:100%;height:auto;" aria-label="No regularization regression comparison">
                    <rect x="0" y="0" width="560" height="220" rx="20" fill="rgba(15,23,42,0.48)"></rect>
                    <g stroke="rgba(148,163,184,0.15)" stroke-width="1">
                      <line x1="26" y1="184" x2="534" y2="184"></line>
                      <line x1="26" y1="28" x2="26" y2="184"></line>
                      <line x1="26" y1="145" x2="534" y2="145"></line>
                      <line x1="26" y1="106" x2="534" y2="106"></line>
                      <line x1="26" y1="67" x2="534" y2="67"></line>
                    </g>
                    <path d="M 26 172 C 52 150, 66 116, 90 112 C 116 108, 138 188, 162 184 C 186 180, 208 48, 234 42 C 258 36, 280 136, 304 138 C 330 140, 352 18, 376 16 C 402 14, 424 108, 448 112 C 474 116, 502 54, 534 78" fill="none" stroke="#fca5a5" stroke-width="4" stroke-linecap="round"></path>
                    ${heroDots()}
                  </svg>
                </div>
                <p>Overfits noise</p>
              </div>
              <div class="compare">
                <h3>With regularization</h3>
                <div style="margin-top:16px;">
                  <svg viewBox="0 0 560 220" style="width:100%;height:auto;" aria-label="With regularization regression comparison">
                    <rect x="0" y="0" width="560" height="220" rx="20" fill="rgba(15,23,42,0.48)"></rect>
                    <g stroke="rgba(148,163,184,0.15)" stroke-width="1">
                      <line x1="26" y1="184" x2="534" y2="184"></line>
                      <line x1="26" y1="28" x2="26" y2="184"></line>
                      <line x1="26" y1="145" x2="534" y2="145"></line>
                      <line x1="26" y1="106" x2="534" y2="106"></line>
                      <line x1="26" y1="67" x2="534" y2="67"></line>
                    </g>
                    <path d="M 26 176 C 92 158, 144 112, 198 92 C 252 72, 308 50, 364 50 C 420 50, 478 70, 534 102" fill="none" stroke="#86efac" stroke-width="4" stroke-linecap="round"></path>
