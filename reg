    function renderModern() {
      viewEl.innerHTML = `
        <h1 class="title">State of the Art</h1>
        <div class="stack">
          <div class="example-row">
            <h3>Classical machine learning</h3>
            <p>Methods like Ridge, Lasso, and Elastic Net are widely used for tabular data. They stabilize models when there are many features or strong correlations, preventing coefficients from becoming large and unstable.</p>
          </div>
          <div class="example-row">
            <h3>Regression in practice</h3>
            <p>Linear regression remains widely used in real systems, especially for structured data. Regularization is almost always applied to control noise and correlation between features, making predictions more stable and reliable.</p>
          </div>
          <div class="example-row">
            <h3>Deep learning</h3>
            <p>Large neural networks are highly flexible but prone to overfitting. Techniques like weight decay (L2), dropout, and early stopping are used during training to control complexity and ensure the model learns general patterns rather than memorizing data.</p>
          </div>
          <div class="example-row">
            <h3>Recommendation systems</h3>
            <p>Platforms like Spotify, Netflix, and YouTube operate on large, sparse datasets. Regularization helps these systems avoid overfitting to specific users or interactions, allowing them to generalize preferences and recommend new, relevant content.</p>
          </div>
          <div class="example-row">
            <h3>Large-scale AI systems (LLMs)</h3>
            <p>Large language models are trained on massive datasets with billions of parameters. Regularization techniques such as weight decay and validation-based early stopping are critical for preventing memorization and ensuring stable training. At this scale, even small overfitting can lead to unreliable outputs, making control of model complexity essential.</p>
          </div>
          <div class="example-row">
            <h3>Dimensionality reduction (SVD)</h3>
            <p>SVD is used to simplify high-dimensional datasets by decomposing them into core components. By keeping only the most important components, it removes noise and redundancy, improving both computational efficiency and model stability.</p>
          </div>
          <p class="lead" style="margin-top:6px; color:#d8e5f6;">State-of-the-art models are not just larger or more complex. The best models are carefully controlled to ensure they generalize reliably to new data.</p>
        </div>
      `;
    }

    function renderQuiz() {
      const question = quizQuestions[activeQuizIndex];

      if (quizComplete) {
        const score = getQuizScore();
        const percentage = Math.round((score / quizQuestions.length) * 100);

        viewEl.innerHTML = `
          <h1 class="title">Quiz</h1>
          <div class="stack">
            <div class="card">
              <h2 class="subtitle" style="margin-top:0; font-size:30px;">Results</h2>
              <p class="lead" style="margin-top:18px;">Score: ${score} / ${quizQuestions.length}</p>
              <p class="lead" style="margin-top:10px;">Percentage: ${percentage}%</p>
              <div class="pills" style="margin-top:24px;">
                <button class="pill active" data-quiz-restart="true">Restart Quiz</button>
              </div>
            </div>
          </div>
        `;

        const restartBtn = document.querySelector("[data-quiz-restart]");
        if (restartBtn) {
          restartBtn.addEventListener("click", () => {
            activeQuizIndex = 0;
            quizSelections = {};
            quizChecked = {};
            quizComplete = false;
            renderView();
          });
        }
        return;
      }

      const selection = quizSelections[question.id];
      const checked = quizChecked[question.id];
      viewEl.innerHTML = `
        <h1 class="title">Quiz</h1>
        <div class="stack">
          <div class="card">
            <p style="margin:0; color:#9aacbf; font-size:14px; line-height:1.6;">Question ${activeQuizIndex + 1} of ${quizQuestions.length}</p>
            <h2 class="subtitle" style="margin-top:14px; font-size:28px;">${question.question}</h2>
            <div style="display:grid; gap:12px; margin-top:26px;">
              ${question.options.map((option, index) => {
                const letter = String.fromCharCode(65 + index);
                const selected = selection === letter;
                const correct = checked && letter === question.correctAnswer;
                const incorrect = checked && selected && letter !== question.correctAnswer;
                return `
                  <button
                    type="button"
                    data-quiz-option="${letter}"
                    class="pill"
                    style="
                      width:100%;
                      text-align:left;
                      justify-content:flex-start;
                      padding:14px 16px;
                      border-color:${correct ? "rgba(134,239,172,0.35)" : incorrect ? "rgba(252,165,165,0.35)" : selected ? "rgba(96,199,255,0.28)" : "rgba(148,163,184,0.12)"};
                      background:${correct ? "rgba(134,239,172,0.10)" : incorrect ? "rgba(252,165,165,0.08)" : selected ? "rgba(96,199,255,0.08)" : "rgba(255,255,255,0.03)"};
                      color:${correct ? "#dfffe9" : incorrect ? "#ffd7d7" : selected ? "#dff4ff" : "var(--text)"};
                    "
                  >${option}</button>
                `;
              }).join("")}
            </div>
            <div class="pills" style="margin-top:24px;">
              <button class="pill" data-quiz-nav="prev" ${activeQuizIndex === 0 ? "disabled" : ""} style="${activeQuizIndex === 0 ? "opacity:0.45; cursor:not-allowed;" : ""}">Previous</button>
              <button class="pill" data-quiz-nav="next">${activeQuizIndex === quizQuestions.length - 1 ? "Finish" : "Next"}</button>
            </div>
          </div>
        </div>
      `;

      document.querySelectorAll("[data-quiz-option]").forEach((button) => {
        button.addEventListener("click", () => {
          quizSelections[question.id] = button.dataset.quizOption;
          renderView();
        });
      });

      document.querySelectorAll("[data-quiz-nav]").forEach((button) => {
        button.addEventListener("click", () => {
          const dir = button.dataset.quizNav;
          if (dir === "prev" && activeQuizIndex > 0) {
            activeQuizIndex -= 1;
          }
          if (dir === "next") {
            if (activeQuizIndex < quizQuestions.length - 1) {
              activeQuizIndex += 1;
            } else {
              quizComplete = true;
            }
          }
          renderView();
        });
      });
    }

    function getQuizScore() {
      return quizQuestions.reduce((score, question) => {
        return score + (quizSelections[question.id] === question.correctAnswer ? 1 : 0);
      }, 0);
    }

